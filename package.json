{
  "name": "nox-app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "oxlint",
    "preview": "vite preview",
    "electron:start": "electron .",
    "dist:win": "npm run build && electron-builder --win portable",
    "dist:win:installer": "npm run build && electron-builder --win nsis",
    "dist:linux": "npm run build && electron-builder --linux AppImage",
    "cap:add:android": "npx cap add android",
    "cap:sync": "npm run build && npx cap sync android",
    "cap:icons": "npx @capacitor/assets generate --android",
    "cap:open:android": "npx cap open android"
  },
  "build": {
    "appId": "com.nox.app",
    "productName": "NOX",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "win": {
      "icon": "electron/icon.png",
      "target": [
        "portable",
        "nsis"
      ]
    },
    "portable": {
      "artifactName": "NOX-Portable.exe"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "artifactName": "NOX-Instalador.exe"
    },
    "linux": {
      "icon": "electron/icon.png",
      "target": [
        "AppImage"
      ]
    }
  },
  "dependencies": {
    "@capacitor/android": "^8.4.2",
    "@capacitor/cli": "^8.4.2",
    "@capacitor/core": "^8.4.2",
    "@capacitor/status-bar": "^8.0.0",
    "@fontsource/chakra-petch": "^5.3.0",
    "@fontsource/share-tech-mono": "^5.3.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "uuid": "^14.0.1"
  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "electron": "^43.2.0",
    "electron-builder": "^26.15.3",
    "oxlint": "^1.71.0",
    "vite": "^8.1.1",
    "vite-plugin-pwa": "^1.3.0"
  }
}
